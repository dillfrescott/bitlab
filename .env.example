# Admin password for the Bitlab web admin panel
ADMIN_PASSWORD=replace-with-a-random-secret

# Session signing secret (used for admin sessions and playback tokens)
SESSION_SECRET=replace-with-another-random-secret

# PostgreSQL password
POSTGRES_PASSWORD=replace-with-a-postgres-password

# TMDB API key for metadata enrichment
TMDB_API_KEY=replace-with-your-tmdb-api-key

# VPN Settings (AirVPN with WireGuard)
VPN_SERVICE_PROVIDER=airvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_airvpn_wireguard_private_key_here
WIREGUARD_ADDRESSES=10.x.x.x/32 # e.g. 10.188.x.x/32 from AirVPN Config Generator

# Option A: Built-in provider filters (uncomment if desired)
# SERVER_COUNTRIES=Netherlands

# Option B: Direct Custom Endpoint (uncomment if using VPN_SERVICE_PROVIDER=custom)
# WIREGUARD_ENDPOINT_IP=your_airvpn_server_ip
# WIREGUARD_ENDPOINT_PORT=1637
# WIREGUARD_PUBLIC_KEY=your_airvpn_server_public_key
