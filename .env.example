# Admin password for the Bitlab web admin panel
ADMIN_PASSWORD=replace-with-a-random-secret

# Session signing secret (used for admin sessions and playback tokens)
SESSION_SECRET=replace-with-another-random-secret

# PostgreSQL password
POSTGRES_PASSWORD=replace-with-a-postgres-password

# TMDB API key for metadata enrichment
TMDB_API_KEY=replace-with-your-tmdb-api-key

# --- Custom WireGuard Configuration ---
# Uncomment the block below to use a custom WireGuard configuration:
# WIREGUARD_PRIVATE_KEY=your-wireguard-private-key
# WIREGUARD_ADDRESSES=your-wireguard-address-cidr # e.g. 10.14.0.2/16
# WIREGUARD_ENDPOINT_IP=your-wireguard-endpoint-ip # MUST be a numeric IP address (not a domain name)
# WIREGUARD_ENDPOINT_PORT=your-wireguard-endpoint-port
# WIREGUARD_PUBLIC_KEY=your-wireguard-public-key

# --- Surfshark WireGuard Configuration ---
# Uncomment the block below to use Surfshark natively:
# VPN_SERVICE_PROVIDER=surfshark
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=your-surfshark-private-key
# WIREGUARD_ADDRESSES=your-surfshark-address-cidr # e.g. 10.14.0.2/16
