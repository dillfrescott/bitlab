# Admin password for the Bitlab web admin panel
ADMIN_PASSWORD=replace-with-a-random-secret

# Session signing secret (used for admin sessions and playback tokens)
SESSION_SECRET=replace-with-another-random-secret

# PostgreSQL password
POSTGRES_PASSWORD=replace-with-a-postgres-password

# TMDB API key for metadata enrichment
TMDB_API_KEY=replace-with-your-tmdb-api-key

# Surfshark VPN Credentials (generated from Surfshark Dashboard under Manual Setup -> WireGuard)
SURFSHARK_WIREGUARD_PRIVATE_KEY=your-surfshark-wireguard-private-key
SURFSHARK_WIREGUARD_ADDRESSES=your-surfshark-wireguard-address-cidr # e.g. 10.14.0.2/16
