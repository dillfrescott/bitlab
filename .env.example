# ── Frontend ──────────────────────────────────────────────────────────────────

# The public URL of this service (used to build the addon manifest URL shown on the landing page)
# Example: BASE_URL=https://bitlab.example.com
# If left empty, it will be inferred from the incoming request.
# BASE_URL=

# Port to listen on (default: 7000)
# PORT=7000

# URL of your bitmagnet GraphQL API (default: http://bitmagnet:3333)
# BITMAGNET_URL=http://bitmagnet:3333

# Optional API key for bitmagnet (if authentication is enabled)
# BITMAGNET_API_KEY=

# Timeout (in milliseconds) for fetching metadata from bitmagnet (default: 90000)
# METADATA_TIMEOUT_MS=90000

# ── Bitmagnet ─────────────────────────────────────────────────────────────────

# TMDB API key for enriching torrent metadata with movie/TV info (optional)
# TMDB_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Password for the postgres user (default: postgres — change in production!)
# POSTGRES_PASSWORD=postgres

# Database name (default: bitmagnet)
# POSTGRES_DB=bitmagnet

# Postgres system user (default: postgres)
# PGUSER=postgres

# Host path for persistent postgres data storage
# POSTGRES_DATA_PATH=/mnt/drive/postgres
