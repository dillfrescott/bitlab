# Admin password for the Bitlab web admin panel
ADMIN_PASSWORD=replace-with-a-random-secret

# Session signing secret (used for admin sessions and playback tokens)
SESSION_SECRET=replace-with-another-random-secret

# PostgreSQL password
POSTGRES_PASSWORD=replace-with-a-postgres-password

# TMDB API key for metadata enrichment
TMDB_API_KEY=replace-with-your-tmdb-api-key

# --- VPN provider (WireGuard) ---
# Bitlab ships through gluetun so all torrent traffic egresses over the
# VPN and your host IP (e.g. a Hetzner box) never touches a swarm.
#
# Surfshark is the default and benchmarked ~27% faster than ProtonVPN free
# (NL): ~37 MB/s vs ~29 MB/s through gluetun. Neither Surfshark nor
# ProtonVPN-free support gluetun's VPN_PORT_FORWARDING, so TorrServer runs
# outbound-only. The TorrServer tuning in config/torrserver-settings.json
# (500 conn / 128 MB cache / 100 MB preload) compensates for the lack of
# incoming peers — that was the dominant fix for "loads forever" stalls.
#
# To enable port forwarding later you'd need a gluetun-supported paid
# provider (PIA / ProtonVPN Plus / PrivateVPN / Perfect Privacy). With
# ProtonVPN Plus you'd set VPN_SERVICE_PROVIDER=protonvpn and ONLY pass
# WIREGUARD_PRIVATE_KEY (gluetun resolves endpoint/server-key/addresses
# itself); FREE_ONLY would be removed and SERVER_COUNTRIES can stay.
VPN_SERVICE_PROVIDER=surfshark
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your-surfshark-private-key
WIREGUARD_ADDRESSES=your-surfshark-address-cidr # e.g. 10.14.0.2/16

# Optional: restrict gluetun's server pick to a country. Defaults to
# Netherlands in compose.yaml if unset. Surfshark manages endpoint IP,
# endpoint port, and server public key itself from its built-in list.
# SERVER_COUNTRIES=Netherlands
